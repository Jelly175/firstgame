# ============================================================
# WHAT IS A .env FILE?
#   It stores secret/config values so you don't hardcode them.
#   Never commit your real .env to GitHub!
#
# HOW TO USE:
#   1. Copy this file and rename the copy to just ".env"
#      Command: cp .env.example .env
#   2. Fill in your actual MySQL credentials below
# ============================================================

# Your MySQL host — almost always "localhost" on your own computer
DB_HOST=localhost

# MySQL port — 3306 is the default MySQL port
DB_PORT=3306

# Your MySQL username — Homebrew installs use "root" by default
DB_USER=root

# Your MySQL password — leave blank if Homebrew MySQL has no password
DB_PASSWORD=

# The database name we created in setup.sql
DB_NAME=laundry_db

# The port your Node.js app will run on
# Visit http://localhost:3000 in your browser
PORT=3000

# ============================================================
# SAFE MESSAGING SETTINGS
# These protect your WhatsApp number from being blocked.
#
# MAX_BULK_PER_RUN: How many messages to send per button click.
#   Recommended: 20-30. Never go above 50 in one run.
#
# MESSAGE_DELAY_MIN / MAX: Random wait (in seconds) between
#   each message. Randomness makes it look human, not a bot.
#   Recommended: 20 min, 45 max.
# ============================================================
MAX_BULK_PER_RUN=30
MESSAGE_DELAY_MIN=20
MESSAGE_DELAY_MAX=45
